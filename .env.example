# ====== Neo4j ======
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphenda
NEO4J_DATABASE=neo4j

# ====== LLM provider selection ======
# Provider used for triple extraction and community summarization.
# Supported: anthropic, openai, deepseek, groq, openrouter, lmstudio, vllm,
#            gemini, ollama, internal-llm, internal-llm-agentic
GRAPHENDA_LLM_PROVIDER=anthropic
# Optional cross-provider overrides; per-provider env vars below win when set.
GRAPHENDA_LLM_MODEL=
GRAPHENDA_LLM_TIMEOUT=120

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---- OpenAI-compatible (also used for deepseek/groq/openrouter/lmstudio/vllm) ----
OPENAI_API_KEY=
# Leave empty to use the preset for the selected provider, or override here.
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ---- Google Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Ollama (local) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ---- Internal corporate /chatCompletion endpoint ----
# Used by both GRAPHENDA_LLM_PROVIDER=internal-llm and internal-llm-agentic.
INTERNAL_LLM_ENDPOINT=http://localhost:5001/chatCompletion
INTERNAL_LLM_USER_UUID=
INTERNAL_LLM_MODEL=

# ====== Paths ======
# Registry path: where publisher.py writes YAMLs. Defaults to ../graphenda-registry/
GRAPHENDA_REGISTRY_PATH=../graphenda-registry
GRAPHENDA_ONTOLOGIES_PATH=./ontologies

# ====== Logging ======
LOG_LEVEL=INFO
LOG_FORMAT=text

# ====== Neo4j ======
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphenda
NEO4J_DATABASE=neo4j

# ====== Anthropic (LLM-assisted extraction) ======
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ====== Paths ======
# Registry path: where publisher.py writes YAMLs. Defaults to ../graphenda-registry/
GRAPHENDA_REGISTRY_PATH=../graphenda-registry
GRAPHENDA_ONTOLOGIES_PATH=./ontologies

# ====== Logging ======
LOG_LEVEL=INFO
LOG_FORMAT=text
